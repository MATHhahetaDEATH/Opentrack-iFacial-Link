<Window x:Class="VTubeLink.MapMonitorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:VTubeLink"
        Title="Mapping Monitor &amp; Logs" Height="600" Width="800"
        Icon="app_icon.png"
        FontFamily="Segoe UI" Background="#F8F8F8">
    <Window.Resources>
        <local:TagColorConverter x:Key="TagColorConverter" />
        <Style x:Key="RightAlignStyle" TargetType="TextBlock">
            <Setter Property="TextAlignment" Value="Right"/>
        </Style>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="1.2*"/>
        </Grid.ColumnDefinitions>

        <!-- Mapping Section -->
        <Border Grid.Column="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Parameter Mapping" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10" Foreground="#333"/>
                
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- ARKit -->
                    <DockPanel Grid.Column="0" Margin="0,0,5,0">
                        <TextBlock DockPanel.Dock="Top" Text="ARKit (Raw)" Foreground="#666" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,5"/>
                        <DataGrid x:Name="ArkitGrid" AutoGenerateColumns="False" HeadersVisibility="None" 
                                  CanUserAddRows="False" IsReadOnly="True" GridLinesVisibility="None" RowHeight="22" Background="Transparent" BorderThickness="0" FontSize="11">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding Key}" Width="*" Foreground="#444" FontFamily="Consolas"/>
                                <DataGridTextColumn Binding="{Binding Value, StringFormat=F3}" Width="45" Foreground="#005A9E" FontFamily="Consolas" ElementStyle="{StaticResource RightAlignStyle}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>

                    <!-- Mapped -->
                    <DockPanel Grid.Column="1" Margin="5,0,0,0">
                        <TextBlock DockPanel.Dock="Top" Text="Opentrack &amp; Custom" Foreground="#666" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,5"/>
                        <DataGrid x:Name="MappedGrid" AutoGenerateColumns="False" HeadersVisibility="None" 
                                  CanUserAddRows="False" IsReadOnly="True" GridLinesVisibility="None" RowHeight="22" Background="Transparent" BorderThickness="0" FontSize="11">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding Key}" Width="*" Foreground="#444" FontFamily="Consolas"/>
                                <DataGridTextColumn Binding="{Binding Value, StringFormat=F3}" Width="45" Foreground="#107C10" FontFamily="Consolas" ElementStyle="{StaticResource RightAlignStyle}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Grid>
            </Grid>
        </Border>

        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center" Background="Transparent"/>

        <!-- Logs Section -->
        <Border Grid.Column="2" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <TextBlock Text="Service Logs" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#333"/>
                
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Filters:" FontSize="12" Foreground="#666" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <CheckBox x:Name="ChkLogUdp" Content="UDP" IsChecked="True" Margin="0,0,10,0" Checked="Filter_Changed" Unchecked="Filter_Changed"/>
                    <CheckBox x:Name="ChkLogOpt" Content="OPT" IsChecked="True" Margin="0,0,10,0" Checked="Filter_Changed" Unchecked="Filter_Changed"/>
                    <CheckBox x:Name="ChkLogSys" Content="SYS" IsChecked="True" Margin="0,0,10,0" Checked="Filter_Changed" Unchecked="Filter_Changed"/>
                    <Button Content="Clear Logs" Padding="10,0" Margin="20,0,0,0" Click="BtnClearLogs_Click"/>
                </StackPanel>

                <ListBox x:Name="LogListBox" Grid.Row="2" FontFamily="Consolas" FontSize="11" BorderThickness="1" BorderBrush="#EEE"
                         VirtualizingPanel.ScrollUnit="Pixel" Background="#FAFAFA" SelectionMode="Single">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Message}" TextWrapping="Wrap" Foreground="{Binding Tag, Converter={StaticResource TagColorConverter}}"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</Window>
