<Window x:Class="VTubeLink.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VTubeLink Utility" Height="300" Width="350"
        Icon="app_icon.png"
        ResizeMode="CanResize" WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" Background="#F0F0F0"
        StateChanged="Window_StateChanged" Closing="Window_Closing">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="VTube-IFacial-Link" FontSize="16" FontWeight="Bold" Margin="0,0,0,15" Foreground="#333333"/>

        <!-- iFacialMocap Section -->
        <StackPanel Grid.Row="1" Margin="0,0,0,15">
            <TextBlock Text="iFacialMocap IP Address:" FontSize="12" Margin="0,0,0,5" Foreground="#555555"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="IpTextBox" Height="24" MaxLength="15" VerticalContentAlignment="Center" Margin="0,0,10,0"/>
                <Button x:Name="ToggleUdpButton" Grid.Column="1" Content="Start" Height="24" Click="ToggleUdpButton_Click"/>
            </Grid>
            <StackPanel Orientation="Horizontal" Margin="0,5,0,0" VerticalAlignment="Center">
                <Ellipse x:Name="UdpStatusIndicator" Width="10" Height="10" Fill="Red" Margin="0,0,5,0"/>
                <TextBlock x:Name="UdpStatusText" Text="Disconnected" FontSize="11" Foreground="#777777"/>
            </StackPanel>
        </StackPanel>

        <!-- Opentrack Section -->
        <StackPanel Grid.Row="2" Margin="0,0,0,15">
            <TextBlock Text="Opentrack UDP Connection:" FontSize="12" Margin="0,0,0,5" Foreground="#555555"/>
            <Button x:Name="ToggleOpentrackButton" Content="Connect to Opentrack" Height="24" HorizontalAlignment="Left" Width="140" Click="ToggleOpentrackButton_Click"/>
            <StackPanel Orientation="Horizontal" Margin="0,5,0,0" VerticalAlignment="Center">
                <Ellipse x:Name="OpentrackStatusIndicator" Width="10" Height="10" Fill="Red" Margin="0,0,5,0"/>
                <TextBlock x:Name="OpentrackStatusText" Text="Disconnected" FontSize="11" Foreground="#777777"/>
            </StackPanel>
        </StackPanel>

        <Button x:Name="ForceStopButton" Grid.Row="3" Content="Force Stop Service" Height="24" Width="120" HorizontalAlignment="Left" Foreground="White" Background="#D32F2F" BorderThickness="0" Click="ForceStopButton_Click" Margin="0,0,0,10"/>
        
        <Button x:Name="ShowMonitorButton" Grid.Row="3" Content="Show Mapping Monitor" Height="24" Width="150" HorizontalAlignment="Right" Click="ShowMonitorButton_Click" Margin="0,0,0,10"/>
        
        <TextBlock Grid.Row="4" Text="Running in background mode. Close window to minimize to tray." FontSize="10" Foreground="#999999" VerticalAlignment="Bottom" TextWrapping="Wrap"/>
    </Grid>
</Window>
